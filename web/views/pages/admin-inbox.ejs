<%- include('../partials/header', { title: 'Hộp thư góp ý' }) %>

<% const unhandledCount = feedbacks.filter(c => !c.handled).length; %>
<div class="inbox-container" style="max-width: 800px; margin: 0 auto; padding: 20px 0;">
  <div class="card" style="margin-bottom: 24px;">
    <h1 class="forum-title" style="display: flex; align-items: center; gap: 8px;">
      <%- include('../partials/icons', { name: 'inbox', size: 24, style: 'color: var(--primary-blue)' }) %> Hộp thư góp ý
      <% if (unhandledCount > 0) { %>
        <span class="nav-badge" style="margin-left: 8px; min-width: 24px; height: 24px; font-size: 12px;"><%= unhandledCount %></span>
      <% } %>
    </h1>
    <p style="font-size: 14px; color: var(--slate-400); font-weight: 600; margin-top: 4px;">
      Các ý kiến/liên hệ do người dùng gửi về (<%= feedbacks.length %>) &mdash;
      <% if (unhandledCount > 0) { %>
        <span style="color: var(--amber); font-weight: 750;"> <%= unhandledCount %> chưa xử lý</span>
      <% } else { %>
        <span style="color: var(--green); font-weight: 750;"> Tất cả đã xử lý</span>
      <% } %>
    </p>
  </div>

  <% if (locals.error) { %>
    <div class="alert alert-danger" style="margin-bottom: 20px;"><%= error %></div>
  <% } %>
  <% if (locals.success) { %>
    <div class="alert alert-success" style="margin-bottom: 20px;"><%= success %></div>
  <% } %>

  <div class="inbox-list" style="display: flex; flex-direction: column; gap: 16px;">
    <% if (feedbacks.length === 0) { %>
      <div class="card text-center" style="padding: 48px 16px; color: var(--slate-500); font-weight: 600;">
        Không có góp ý nào trong hộp thư.
      </div>
    <% } else { %>
      <% feedbacks.forEach(fb => { %>
        <div class="card" style="padding: 24px; border-left: 4px solid <%= fb.handled ? 'var(--slate-300)' : 'var(--primary-blue)' %>; opacity: <%= fb.handled ? '0.8' : '1' %>;">
          <div style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; flex-wrap: wrap; gap: 8px;">
            <div>
              <h3 style="font-size: 16px; font-weight: 800; color: var(--slate-900); margin-bottom: 2px;"><%= fb.name %></h3>
              <p style="font-size: 13px; color: var(--slate-500); font-weight: 500;">
                Email: <a href="mailto:<%= fb.email %>" style="color: var(--primary-blue); text-decoration: none;"><%= fb.email %></a>
                &bull; <%= new Date(fb.createdAt).toLocaleString('vi-VN') %>
              </p>
            </div>
            
            <div style="display: flex; align-items: center; gap: 8px;">
              <% if (fb.handled) { %>
                <span class="badge badge-slate" style="background-color: var(--slate-100); color: var(--slate-600); font-weight: 700; padding: 4px 10px;">Đã xử lý</span>
              <% } else { %>
                <span class="badge badge-primary" style="background-color: var(--primary-light); color: var(--primary-blue); font-weight: 700; padding: 4px 10px;">Chưa xử lý</span>
              <% } %>
            </div>
          </div>

          <div style="font-size: 14px; color: var(--slate-700); line-height: 1.6; white-space: pre-wrap; margin-bottom: 16px;"><%= fb.message %></div>

          <!-- Attachments preview -->
          <% if (fb.media && fb.media.length > 0) { %>
            <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-bottom: 16px;">
              <% fb.media.forEach((m, i) => { %>
                <% if (m.type === 'video') { %>
                  <div style="grid-column: span 2; aspect-ratio: 16/9; border-radius: 8px; overflow: hidden; border: 1px solid var(--slate-200); background-color: #0f172a;">
                    <video src="<%= m.url %>" controls style="width: 100%; height: 100%; object-fit: contain;"></video>
                  </div>
                <% } else { %>
                  <div style="border-radius: 8px; overflow: hidden; border: 1px solid var(--slate-200); aspect-ratio: 1/1; cursor: pointer;" onclick="openMediaLightbox('<%= m.url %>')">
                    <img src="<%= m.url %>" alt="" style="width: 100%; height: 100%; object-fit: cover;" loading="lazy" />
                  </div>
                <% } %>
              <% }) %>
            </div>
          <% } %>

          <div style="display: flex; gap: 8px; justify-content: flex-end; border-top: 1px solid var(--slate-100); padding-top: 12px; margin-top: 12px;">
            <form method="POST" action="/about/<%= fb.id %>/toggle">
              <button type="submit" class="btn btn-secondary" style="padding: 6px 12px; font-size: 13px; font-weight: 700;">
                <%= fb.handled ? 'Đánh dấu chưa xử lý' : 'Đánh dấu đã xử lý' %>
              </button>
            </form>
            <form method="POST" action="/about/<%= fb.id %>/delete" onsubmit="handleDeleteFormSubmit(event, 'Bạn có chắc chắn muốn xóa thư đóng góp này?')">
              <button type="submit" class="btn btn-danger" style="padding: 6px 12px; font-size: 13px; font-weight: 700; background-color: var(--red); color: var(--white); border: none; border-radius: var(--radius-md);">
                Xóa
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<!-- Media Lightbox Modal -->
<div id="media-lightbox" class="modal-overlay" style="display: none; background-color: rgba(15, 23, 42, 0.95);" onclick="closeMediaLightbox()">
  <div style="position: absolute; top: 16px; right: 16px; z-index: 50;">
    <button type="button" class="btn-icon" style="color: var(--white); background-color: rgba(255,255,255,0.1);" onclick="closeMediaLightbox()">
      <%- include('../partials/icons', { name: 'x', size: 24 }) %>
    </button>
  </div>
  <div style="max-width: 90%; max-height: 90%; display: flex; align-items: center; justify-content: center;" onclick="event.stopPropagation()">
    <img id="lightbox-image" src="" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain; border-radius: var(--radius-lg);" />
  </div>
</div>

<%- include('../partials/footer') %>
