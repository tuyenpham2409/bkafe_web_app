<div id="ad-popup-modal" class="modal-overlay" style="display: none;">
  <div class="modal-container" style="max-width: 400px; width: 90%;">
    <button id="ad-popup-close-btn" class="modal-close-btn">
      <%- include('icons', { name: 'x', size: 20 }) %>
    </button>
    <div class="modal-content" style="text-align: center; padding: 20px;">
      <div class="modal-icon" style="width: 64px; height: 64px; background-color: var(--primary-light); color: var(--primary-blue); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px;">
        <%- include('icons', { name: 'coffee', size: 32 }) %>
      </div>
      <h3 class="modal-title" style="font-size: 20px; font-weight: 900; color: var(--slate-900); margin-bottom: 8px;">Ưu đãi BKafe!</h3>
      <p class="modal-desc" style="font-size: 14px; color: var(--slate-500); margin-bottom: 20px; font-weight: 500;">Tham gia ngay cộng đồng sinh viên HUST để nhận tài liệu ôn thi độc quyền hoàn toàn miễn phí.</p>
      <button id="ad-popup-action-btn" class="btn btn-primary modal-btn" style="width: 100%;">Khám phá ngay</button>
    </div>
  </div>
</div>
