<%
const pwName = locals.name || 'password';
const pwId = locals.id || pwName;
const pwPlaceholder = locals.placeholder || '••••••••';
const pwAutocomplete = locals.autocomplete || '';
const pwRequired = locals.required !== false;
%>
<div class="relative">
  <input
    type="password"
    id="<%= pwId %>"
    name="<%= pwName %>"
    <%= pwRequired ? 'required' : '' %>
    autocomplete="<%= pwAutocomplete %>"
    class="form-input"
    style="padding-right: 44px;"
    placeholder="<%= pwPlaceholder %>"
  >
  <button
    type="button"
    class="btn-icon toggle-password-btn"
    data-target="<%= pwId %>"
    tabindex="-1"
    title="Hiện mật khẩu"
    style="position: absolute; right: 12px; top: 50%; transform: translateY(-50%); padding: 4px; display: flex; align-items: center; justify-content: center;"
  >
    <span class="icon-eye"><%- include('icons', { name: 'eye', size: 18 }) %></span>
    <span class="icon-eye-off" style="display: none;"><%- include('icons', { name: 'eye-off', size: 18 }) %></span>
  </button>
</div>
