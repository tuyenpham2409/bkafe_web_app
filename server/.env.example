# ---- BKafe API config ----
PORT=5000
# MongoDB connection (Docker local mongo by default)
MONGO_URI=mongodb://127.0.0.1:27017/bkafe
# Secret for signing JWT access tokens
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES=7d
# Public base URL of this API (used to build absolute media URLs)
API_URL=http://localhost:5000
# Comma separated list of allowed web/mobile origins (CORS). Empty = allow all.
CORS_ORIGINS=
# Default password used when seeding sample accounts
SEED_PASSWORD=Abc123@
